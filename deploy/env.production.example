# ==============================================
# Variáveis de ambiente — Produção (VPS Hostinger)
# ==============================================
# Copie este arquivo para: /home/deploy/relatoriocep/backend/.env
# e preencha os valores reais.

# Django
SECRET_KEY=coloque-uma-chave-secreta-longa-e-aleatoria-aqui
DEBUG=False
ALLOWED_HOSTS=seudominio.com,www.seudominio.com,IP_DA_VPS

# Banco de dados PostgreSQL
DATABASE_URL=postgres://relatoriocep_user:SUA_SENHA_FORTE@localhost:5432/relatoriocep_db

# CORS e CSRF (domínio do frontend — neste caso, mesmo servidor)
CORS_ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com
CSRF_TRUSTED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# Groq AI
GROQ_API_KEY=gsk_sua_chave_groq_aqui

# Google Sheets (caminho para o JSON de credenciais)
GOOGLE_CREDENTIALS_FILE=/home/deploy/relatoriocep/backend/credentials/google_service_account.json

# E-mail (opcional — para recuperação de senha)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app

# OAuth — Login social (Google)
# Crie em https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=seu-google-client-secret

# URL do frontend (para links de e-mail e callbacks OAuth)
FRONTEND_URL=https://seudominio.com
