# =============================================
# Variáveis de ambiente da aplicação RelatorioCEP
# =============================================

# Django
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (SQLite por padrão; troque para PostgreSQL em produção)
DATABASE_URL=sqlite:///db.sqlite3

# CORS - origens do frontend permitidas
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================
# Google Sheets / Google API
# =============================================
# Caminho para o arquivo de credenciais de Service Account (JSON)
GOOGLE_CREDENTIALS_FILE=credentials/google_service_account.json

# =============================================
# Groq AI - chave de API
# =============================================
GROQ_API_KEY=sua-chave-groq-aqui

# =============================================
# E-mail (para recuperação de senha)
# =============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app

# =============================================
# Celery / Redis (opcional para tarefas assíncronas)
# =============================================
CELERY_BROKER_URL=redis://localhost:6379/0
